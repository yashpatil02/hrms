generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(EMPLOYEE)
  createdAt      DateTime @default(now())
  weeklyOff      String?
  weekoffBalance Int      @default(0)

  // ── NEW PROFILE FIELDS ──
  phone          String?
  department     String?
  designation    String?
  joinDate       DateTime?
  avatar         String?   // URL or base64 (optional)

  attendances Attendance[]
  leaves      Leave[]
  documents   EmployeeDocument[]
  notifications Notification[]

  uploadedDocuments  EmployeeDocument[] @relation("UploadedByAdmin")
  attendanceAudits   AttendanceAudit[]  @relation("AdminAudit")

  salaryStructure    SalaryStructure?
  payrolls           Payroll[]

  documentRequests   DocumentRequest[]    @relation("DocRequests")
  requestedDocuments DocumentRequest[]    @relation("DocRequestedBy")
  passwordResetTokens PasswordResetToken[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  checkIn   String?
  checkOut  String?
  dayType   DayType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date], name: "userId_date")
  @@index([date])
  @@index([dayType])
}

enum DayType {
  FULL
  HALF
  ABSENT
  WEEKOFF
  WEEKOFF_PRESENT
  PENDING_WEEKOFF
  PAID_LEAVE
  PAID_HOLIDAY
}

model Leave {
  id           Int         @id @default(autoincrement())
  userId       Int
  reason       String
  fromDate     DateTime
  toDate       DateTime
  status       LeaveStatus @default(PENDING)
  rejectReason String?
  createdAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Analyst {
  id                Int       @id @default(autoincrement())
  name              String
  department        String
  shift             Shift
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  terminatedAt      DateTime?
  terminationReason String?
  terminatedById    Int?
  terminatedByName  String?

  shiftAttendances ShiftAttendance[]
  attendanceAudits AttendanceAudit[]
  shiftHistory     AnalystShiftHistory[]

  @@index([shift])
  @@index([isActive])
  @@index([shift, isActive])
}

enum Shift {
  MORNING
  AFTERNOON
  GENERAL
  EVENING
  NIGHT
}

model ShiftAttendance {
  id        Int              @id @default(autoincrement())
  analystId Int
  date      DateTime
  shift     Shift
  status    AttendanceStatus
  createdAt DateTime         @default(now())

  analyst Analyst @relation(fields: [analystId], references: [id])

  @@unique([analystId, date])
  @@index([date])
  @@index([shift])
  @@index([date, shift])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  PAID_LEAVE
}

model AttendanceAudit {
  id        Int               @id @default(autoincrement())
  adminId   Int
  analystId Int
  date      DateTime
  shift     Shift
  oldStatus AttendanceStatus?
  newStatus AttendanceStatus
  action    AuditAction
  createdAt DateTime          @default(now())

  admin   User    @relation("AdminAudit", fields: [adminId], references: [id])
  analyst Analyst @relation(fields: [analystId], references: [id])
}

enum AuditAction {
  CREATE
  UPDATE
}

model AnalystShiftHistory {
  id        Int      @id @default(autoincrement())
  analystId Int
  shift     String
  month     Int
  year      Int
  createdAt DateTime @default(now())

  analyst Analyst @relation(fields: [analystId], references: [id], onDelete: Cascade)

  @@index([analystId, month, year])
}

model UserInvite {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  role       Role     @default(EMPLOYEE)
  department String?
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   Int
  uploadedBy   Int
  documentType String
  fileName     String
  fileUrl      String
  publicId     String?
  mimeType     String
  fileSize     Int
  createdAt    DateTime @default(now())

  employee User @relation(fields: [employeeId], references: [id])
  admin    User @relation("UploadedByAdmin", fields: [uploadedBy], references: [id])

  @@index([employeeId])
  @@index([uploadedBy])
  @@index([createdAt])
}

model DocumentRequest {
  id           Int      @id @default(autoincrement())
  userId       Int
  requestedBy  Int
  documentType String
  message      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  fulfilledAt  DateTime?

  user            User @relation("DocRequests",    fields: [userId],      references: [id])
  requestedByUser User @relation("DocRequestedBy", fields: [requestedBy], references: [id])

  @@index([userId])
  @@index([status])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  title     String
  message   String
  type      String
  entityId  Int?
  entity    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ── NEW: System-wide key-value settings ──
model SystemSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ── HOLIDAY MODULE ──
model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  type        HolidayType @default(PUBLIC)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

enum HolidayType {
  PUBLIC
  OPTIONAL
  RESTRICTED
}

// ── PAYROLL MODULE ──
model SalaryStructure {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  basicSalary     Float    @default(0)
  hra             Float    @default(0)
  da              Float    @default(0)
  otherAllowances Float    @default(0)

  pfEmployee      Float    @default(12)   // % of basic
  pfEmployer      Float    @default(12)   // % of basic (info only)
  esiEmployee     Float    @default(0.75) // % of gross
  esiEmployer     Float    @default(3.25) // % of gross (info only)
  professionalTax Float    @default(0)    // fixed monthly amount
  tds             Float    @default(0)    // fixed monthly amount
  otherDeductions Float    @default(0)    // fixed monthly amount

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrolls        Payroll[]
}

model Payroll {
  id                  Int           @id @default(autoincrement())
  userId              Int
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month               Int
  year                Int

  salaryStructureId   Int?
  salaryStructure     SalaryStructure? @relation(fields: [salaryStructureId], references: [id])

  totalWorkingDays    Int           @default(0)
  presentDays         Float         @default(0)
  absentDays          Float         @default(0)
  leaveDays           Float         @default(0)
  weekoffDays         Int           @default(0)
  paidHolidays        Int           @default(0)

  basicSalary         Float         @default(0)
  hra                 Float         @default(0)
  da                  Float         @default(0)
  otherAllowances     Float         @default(0)
  grossSalary         Float         @default(0)

  pfDeduction         Float         @default(0)
  esiDeduction        Float         @default(0)
  professionalTax     Float         @default(0)
  tds                 Float         @default(0)
  otherDeductions     Float         @default(0)
  totalDeductions     Float         @default(0)

  netSalary           Float         @default(0)

  status              PayrollStatus @default(DRAFT)
  generatedById       Int?
  approvedById        Int?
  approvedAt          DateTime?
  remarks             String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([userId, month, year])
  @@index([month, year])
  @@index([status])
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}
