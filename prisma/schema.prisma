generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(EMPLOYEE)
  createdAt      DateTime @default(now())
  weeklyOff      String?
  weekoffBalance Int      @default(0)

  // ── NEW PROFILE FIELDS ──
  phone          String?
  department     String?
  designation    String?
  joinDate       DateTime?
  avatar         String?   // URL or base64 (optional)
  overtimeRatePerHour Float @default(0)

  // ── PERSONAL DETAILS ──
  dateOfBirth    DateTime?
  gender         String?    // MALE / FEMALE / OTHER
  bloodGroup     String?
  address        String?
  city           String?
  state          String?
  pincode        String?

  // ── EMERGENCY CONTACT ──
  emergencyName  String?
  emergencyPhone String?
  emergencyRel   String?    // relation: Father, Mother, Spouse, etc.

  // ── BANK DETAILS ──
  bankName       String?
  bankAccount    String?    // store masked on display only
  bankIFSC       String?
  bankHolder     String?

  // ── EMPLOYMENT EXTRAS ──
  employeeCode   String?    // EMP001
  panNumber      String?

  attendances Attendance[]
  leaves      Leave[]
  documents   EmployeeDocument[]
  notifications Notification[]

  uploadedDocuments  EmployeeDocument[] @relation("UploadedByAdmin")
  attendanceAudits   AttendanceAudit[]  @relation("AdminAudit")

  salaryStructure    SalaryStructure?
  payrolls           Payroll[]

  documentRequests   DocumentRequest[]    @relation("DocRequests")
  requestedDocuments DocumentRequest[]    @relation("DocRequestedBy")
  passwordResetTokens PasswordResetToken[]
  dailyTargets        DailyTarget[]

  // QC relations
  qcSessions          QCSession[]          @relation("QCManager")
  qcSessionEmployees  QCSessionEmployee[]  @relation("QCEmployee")
  qcErrors            QCError[]            @relation("QCErrors")
  qcDisputes          QCDispute[]          @relation("QCDisputes")

  // Management audit
  managementAudits    ManagementAudit[]    @relation("AuditActor")

  // Shift roster (day-wise)
  shiftRosters        ShiftRoster[]        @relation("UserRoster")
  createdRosters      ShiftRoster[]        @relation("RosterCreator")
  swapRequestsSent    ShiftSwapRequest[]   @relation("SwapRequester")
  swapRequestsReceived ShiftSwapRequest[]  @relation("SwapTarget")

  // Monthly shift schedule
  monthlyShifts       MonthlyShiftSchedule[] @relation("UserMonthlyShift")
  createdMonthlyShifts MonthlyShiftSchedule[] @relation("MonthlyShiftCreator")

  // ATS
  jobsCreated          JobPosting[]             @relation("JobCreator")
  candidatesAdded      Candidate[]              @relation("CandidateAddedBy")
  stageChanges         CandidateStageHistory[]  @relation("StageChangedBy")
  interviewFeedbacks   InterviewFeedback[]      @relation("FeedbackInterviewer")

  // LMS
  trainingsCreated     Training[]               @relation("TrainingCreator")
  trainingAssignments  TrainingAssignment[]     @relation("AssignedTraining")
  assignedTrainings    TrainingAssignment[]     @relation("TrainingAssignedBy")
  quizAttempts         QuizAttempt[]            @relation("QuizAttempts")
  certificates         TrainingCertificate[]    @relation("UserCertificates")
}

// ── MANAGEMENT AUDIT TRAIL ──
model ManagementAudit {
  id             Int      @id @default(autoincrement())
  actorId        Int
  actorName      String
  actorRole      String
  action         String
  entity         String
  entityId       Int?
  description    String
  targetUserId   Int?
  targetUserName String?
  metadata       Json?
  createdAt      DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@index([targetUserId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime
  checkIn   String?
  checkOut  String?
  dayType   DayType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date], name: "userId_date")
  @@index([date])
  @@index([dayType])
}

enum DayType {
  FULL
  HALF
  ABSENT
  WEEKOFF
  WEEKOFF_PRESENT
  PENDING_WEEKOFF
  PAID_LEAVE
  PAID_HOLIDAY
}

model Leave {
  id           Int         @id @default(autoincrement())
  userId       Int
  reason       String
  fromDate     DateTime
  toDate       DateTime
  status       LeaveStatus @default(PENDING)
  rejectReason String?
  createdAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Analyst {
  id                Int       @id @default(autoincrement())
  name              String
  department        String
  shift             Shift
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  terminatedAt      DateTime?
  terminationReason String?
  terminatedById    Int?
  terminatedByName  String?

  shiftAttendances ShiftAttendance[]
  attendanceAudits AttendanceAudit[]
  shiftHistory     AnalystShiftHistory[]

  @@index([shift])
  @@index([isActive])
  @@index([shift, isActive])
}

enum Shift {
  MORNING
  AFTERNOON
  GENERAL
  EVENING
  NIGHT
}

model ShiftAttendance {
  id        Int              @id @default(autoincrement())
  analystId Int
  date      DateTime
  shift     Shift
  status    AttendanceStatus
  createdAt DateTime         @default(now())

  analyst Analyst @relation(fields: [analystId], references: [id])

  @@unique([analystId, date])
  @@index([date])
  @@index([shift])
  @@index([date, shift])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  PAID_LEAVE
}

model AttendanceAudit {
  id        Int               @id @default(autoincrement())
  adminId   Int
  analystId Int
  date      DateTime
  shift     Shift
  oldStatus AttendanceStatus?
  newStatus AttendanceStatus
  action    AuditAction
  createdAt DateTime          @default(now())

  admin   User    @relation("AdminAudit", fields: [adminId], references: [id])
  analyst Analyst @relation(fields: [analystId], references: [id])
}

enum AuditAction {
  CREATE
  UPDATE
}

model AnalystShiftHistory {
  id        Int      @id @default(autoincrement())
  analystId Int
  shift     String
  month     Int
  year      Int
  createdAt DateTime @default(now())

  analyst Analyst @relation(fields: [analystId], references: [id], onDelete: Cascade)

  @@index([analystId, month, year])
}

model UserInvite {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  role       Role     @default(EMPLOYEE)
  department String?
  token      String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   Int
  uploadedBy   Int
  documentType String
  fileName     String
  fileUrl      String
  publicId     String?
  mimeType     String
  fileSize     Int
  createdAt    DateTime @default(now())

  employee User @relation(fields: [employeeId], references: [id])
  admin    User @relation("UploadedByAdmin", fields: [uploadedBy], references: [id])

  @@index([employeeId])
  @@index([uploadedBy])
  @@index([createdAt])
}

model DocumentRequest {
  id           Int      @id @default(autoincrement())
  userId       Int
  requestedBy  Int
  documentType String
  message      String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  fulfilledAt  DateTime?

  user            User @relation("DocRequests",    fields: [userId],      references: [id])
  requestedByUser User @relation("DocRequestedBy", fields: [requestedBy], references: [id])

  @@index([userId])
  @@index([status])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  title     String
  message   String
  type      String
  entityId  Int?
  entity    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ── NEW: System-wide key-value settings ──
model SystemSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ── HOLIDAY MODULE ──
model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  type        HolidayType @default(PUBLIC)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

enum HolidayType {
  PUBLIC
  OPTIONAL
  RESTRICTED
}

// ── PAYROLL MODULE ──
model SalaryStructure {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  basicSalary     Float    @default(0)
  hra             Float    @default(0)
  da              Float    @default(0)
  otherAllowances Float    @default(0)

  pfEmployee      Float    @default(12)   // % of basic
  pfEmployer      Float    @default(12)   // % of basic (info only)
  esiEmployee     Float    @default(0.75) // % of gross
  esiEmployer     Float    @default(3.25) // % of gross (info only)
  professionalTax Float    @default(0)    // fixed monthly amount
  tds             Float    @default(0)    // fixed monthly amount
  otherDeductions Float    @default(0)    // fixed monthly amount

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrolls        Payroll[]
}

model Payroll {
  id                  Int           @id @default(autoincrement())
  userId              Int
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month               Int
  year                Int

  salaryStructureId   Int?
  salaryStructure     SalaryStructure? @relation(fields: [salaryStructureId], references: [id])

  totalWorkingDays    Int           @default(0)
  presentDays         Float         @default(0)
  absentDays          Float         @default(0)
  leaveDays           Float         @default(0)
  weekoffDays         Int           @default(0)
  paidHolidays        Int           @default(0)

  basicSalary         Float         @default(0)
  hra                 Float         @default(0)
  da                  Float         @default(0)
  otherAllowances     Float         @default(0)
  grossSalary         Float         @default(0)

  pfDeduction         Float         @default(0)
  esiDeduction        Float         @default(0)
  professionalTax     Float         @default(0)
  tds                 Float         @default(0)
  otherDeductions     Float         @default(0)
  totalDeductions     Float         @default(0)

  netSalary           Float         @default(0)

  status              PayrollStatus @default(DRAFT)
  generatedById       Int?
  approvedById        Int?
  approvedAt          DateTime?
  remarks             String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([userId, month, year])
  @@index([month, year])
  @@index([status])
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

// ── DAILY TARGET / PRODUCTIVITY ──
model DailyTarget {
  id            Int      @id @default(autoincrement())
  userId        Int
  date          DateTime
  counts        Json
  totalHours    Float    @default(0)
  overtime      Json?
  overtimeHours Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ── QC ERROR TRACKING ──

model QCSession {
  id        Int      @id @default(autoincrement())
  managerId Int
  gameDate  DateTime
  gameName  String
  gameId    String?
  sport     QCSport
  league    String
  qcType    QCType
  createdAt DateTime @default(now())

  manager   User                @relation("QCManager", fields: [managerId], references: [id])
  employees QCSessionEmployee[]
  errors    QCError[]

  @@index([managerId])
  @@index([gameDate])
  @@index([sport])
}

model QCSessionEmployee {
  id         Int    @id @default(autoincrement())
  sessionId  Int
  employeeId Int
  fromTime   String // "HH:MM:SS"
  toTime     String // "HH:MM:SS"

  session  QCSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee User      @relation("QCEmployee", fields: [employeeId], references: [id])

  @@index([sessionId])
  @@index([employeeId])
}

model QCError {
  id         Int           @id @default(autoincrement())
  sessionId  Int
  employeeId Int
  timestamp  String        // "HH:MM:SS"
  errorText  String
  status     QCErrorStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  session  QCSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee User       @relation("QCErrors", fields: [employeeId], references: [id])
  disputes QCDispute[]

  @@index([sessionId])
  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
}

model QCDispute {
  id         Int             @id @default(autoincrement())
  errorId    Int
  employeeId Int
  reason     String
  status     QCDisputeStatus @default(PENDING)
  createdAt  DateTime        @default(now())

  error    QCError @relation(fields: [errorId], references: [id], onDelete: Cascade)
  employee User    @relation("QCDisputes", fields: [employeeId], references: [id])

  @@index([errorId])
  @@index([employeeId])
  @@index([status])
}

enum QCSport {
  SOCCER
  ICE_HOCKEY
  FIELD_HOCKEY
  HANDBALL
  BASKETBALL
}

enum QCType {
  REVIEW
  DEEP
}

enum QCErrorStatus {
  PENDING
  VALID
  INVALID
}

enum QCDisputeStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── SHIFT ROSTER ──

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
  APPROVED
}

model ShiftRoster {
  id          Int      @id @default(autoincrement())
  userId      Int
  date        DateTime
  shift       Shift
  note        String?
  createdById Int
  createdAt   DateTime @default(now())

  user        User     @relation("UserRoster",    fields: [userId],      references: [id], onDelete: Cascade)
  createdBy   User     @relation("RosterCreator", fields: [createdById], references: [id])

  swapAsRequester ShiftSwapRequest[] @relation("RequesterRoster")
  swapAsTarget    ShiftSwapRequest[] @relation("TargetRoster")

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
  @@index([shift])
}

model ShiftSwapRequest {
  id                Int        @id @default(autoincrement())
  requesterId       Int
  targetId          Int
  requesterRosterId Int
  targetRosterId    Int
  reason            String?
  status            SwapStatus @default(PENDING)
  createdAt         DateTime   @default(now())
  resolvedAt        DateTime?
  resolvedById      Int?

  requester       User        @relation("SwapRequester",   fields: [requesterId],       references: [id])
  target          User        @relation("SwapTarget",      fields: [targetId],          references: [id])
  requesterRoster ShiftRoster @relation("RequesterRoster", fields: [requesterRosterId], references: [id])
  targetRoster    ShiftRoster @relation("TargetRoster",    fields: [targetRosterId],    references: [id])

  @@index([requesterId])
  @@index([targetId])
  @@index([status])
  @@index([createdAt])
}

// ── MONTHLY SHIFT SCHEDULE ──

model MonthlyShiftSchedule {
  id          Int      @id @default(autoincrement())
  userId      Int
  year        Int
  month       Int      // 1 = January … 12 = December
  shift       Shift
  note        String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User @relation("UserMonthlyShift",    fields: [userId],      references: [id], onDelete: Cascade)
  createdBy User @relation("MonthlyShiftCreator", fields: [createdById], references: [id])

  @@unique([userId, year, month])
  @@index([year, month])
  @@index([userId])
}

// ── ATS (APPLICANT TRACKING SYSTEM) ──

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum CandidateStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum FeedbackRecommendation {
  HIRE
  REJECT
  HOLD
}

model JobPosting {
  id           Int        @id @default(autoincrement())
  title        String
  department   String?
  description  String
  requirements String?
  location     String?
  type         JobType    @default(FULL_TIME)
  status       JobStatus  @default(OPEN)
  salaryMin    Float?
  salaryMax    Float?
  closingDate  DateTime?
  createdById  Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  createdBy  User        @relation("JobCreator", fields: [createdById], references: [id])
  candidates Candidate[]

  @@index([status])
  @@index([department])
  @@index([createdById])
}

model Candidate {
  id           Int            @id @default(autoincrement())
  name         String
  email        String
  phone        String?
  resumeUrl    String?
  jobId        Int
  stage        CandidateStage @default(APPLIED)
  notes        String?
  offerSalary  Float?
  joiningDate  DateTime?
  offerContent String?
  addedById    Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  job          JobPosting              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  addedBy      User                   @relation("CandidateAddedBy", fields: [addedById], references: [id])
  feedbacks    InterviewFeedback[]
  stageHistory CandidateStageHistory[]

  @@index([jobId])
  @@index([stage])
  @@index([email])
}

model CandidateStageHistory {
  id          Int             @id @default(autoincrement())
  candidateId Int
  fromStage   CandidateStage?
  toStage     CandidateStage
  notes       String?
  changedById Int
  changedAt   DateTime        @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  changedBy User      @relation("StageChangedBy", fields: [changedById], references: [id])

  @@index([candidateId])
}

model InterviewFeedback {
  id             Int                    @id @default(autoincrement())
  candidateId    Int
  interviewerId  Int
  round          String
  rating         Int
  strengths      String?
  weaknesses     String?
  recommendation FeedbackRecommendation
  notes          String?
  createdAt      DateTime               @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewer User      @relation("FeedbackInterviewer", fields: [interviewerId], references: [id])

  @@index([candidateId])
  @@index([interviewerId])
}

// ── LMS (LEARNING MANAGEMENT SYSTEM) ──

enum TrainingStatus {
  DRAFT
  PUBLISHED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model Training {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  category    String?
  duration    Int            // estimated minutes
  content     String         // HTML/text course content
  passingScore Int           @default(70) // quiz passing % (0-100)
  status      TrainingStatus @default(DRAFT)
  createdById Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy    User                  @relation("TrainingCreator", fields: [createdById], references: [id])
  assignments  TrainingAssignment[]
  questions    QuizQuestion[]
  certificates TrainingCertificate[]

  @@index([status])
  @@index([category])
  @@index([createdById])
}

model TrainingAssignment {
  id           Int              @id @default(autoincrement())
  trainingId   Int
  userId       Int
  assignedById Int
  dueDate      DateTime?
  status       AssignmentStatus @default(PENDING)
  progress     Int              @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())

  training     Training             @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user         User                 @relation("AssignedTraining",    fields: [userId],       references: [id])
  assignedBy   User                 @relation("TrainingAssignedBy",  fields: [assignedById], references: [id])
  quizAttempts QuizAttempt[]
  certificate  TrainingCertificate?

  @@unique([trainingId, userId])
  @@index([userId])
  @@index([trainingId])
  @@index([status])
}

model QuizQuestion {
  id            Int      @id @default(autoincrement())
  trainingId    Int
  question      String
  options       String   // JSON: ["opt A","opt B","opt C","opt D"]
  correctAnswer Int      // index 0-3
  points        Int      @default(1)
  order         Int      @default(0)

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@index([trainingId])
}

model QuizAttempt {
  id           Int      @id @default(autoincrement())
  assignmentId Int
  userId       Int
  answers      String   // JSON: {"questionId": selectedIndex, ...}
  score        Int      // percentage 0-100
  passed       Boolean
  attemptNo    Int      @default(1)
  attemptedAt  DateTime @default(now())

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User               @relation("QuizAttempts", fields: [userId], references: [id])

  @@index([assignmentId])
  @@index([userId])
}

model TrainingCertificate {
  id            Int      @id @default(autoincrement())
  assignmentId  Int      @unique
  userId        Int
  trainingId    Int
  certificateNo String   @unique
  issuedAt      DateTime @default(now())

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User               @relation("UserCertificates", fields: [userId],     references: [id])
  training   Training           @relation(fields: [trainingId], references: [id])

  @@index([userId])
  @@index([trainingId])
}
